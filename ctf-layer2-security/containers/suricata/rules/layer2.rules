# ============================================================================
# Reglas Suricata Custom - Deteccion de Ataques de Capa 2
# CTF Layer 2 Security - ARP Spoofing & MAC Flooding
#
# Estrategia de deteccion ARP via pkthdr (raw packet bytes):
#   Estructura Ethernet+ARP en bytes desde inicio del frame:
#     Offset 12-13: EtherType 0x0806 = ARP
#     Offset 20-21: ARP Operation (0x0001=Request, 0x0002=Reply)
#     Offset 22-27: Sender MAC (SHA)
#     Offset 28-31: Sender IP (SPA)
#     Offset 38-41: Target IP (TPA)
#
# Deteccion HTTP via reglas standard (payload inspection).
# ============================================================================

# === DETECCION DE ARP SPOOFING ===

# Regla 1000001: Detecta ARP Reply (operacion = 0x0002)
# EtherType 0x0806 en offset 12, operacion 0x0002 en offset 20
alert pkthdr any any -> any any (msg:"CTF - ARP Reply detectado (posible ARP Spoofing)"; content:"|08 06|"; offset:12; depth:2; content:"|00 02|"; offset:20; depth:2; sid:1000001; rev:4; classtype:misc-attack;)

# Regla 1000002: Alto volumen de ARP Replies (ARP Spoofing activo)
# Umbral: mas de 10 ARP Replies en 5 segundos desde la misma IP origen
alert pkthdr any any -> any any (msg:"CTF - ALERTA: Alto volumen de ARP Replies - ARP Spoofing en progreso"; content:"|08 06|"; offset:12; depth:2; content:"|00 02|"; offset:20; depth:2; threshold:type both, track by_src, count 10, seconds 5; sid:1000002; rev:4; classtype:misc-attack;)

# Regla 1000010: Volumen anomalo de ARP Requests (MAC Flooding)
# track by_rule (no by_src): mac_flood usa MACs origen aleatorias en cada paquete,
# por lo que nunca acumula 50 desde el mismo origen. by_rule cuenta el total global.
alert pkthdr any any -> any any (msg:"CTF - ALERTA: Volumen anomalo de paquetes ARP - posible MAC Flooding"; content:"|08 06|"; offset:12; depth:2; content:"|00 01|"; offset:20; depth:2; threshold:type both, track by_rule, count 50, seconds 3; sid:1000010; rev:5; classtype:misc-attack;)

# === DETECCION DE TRAFICO SOSPECHOSO (HTTP) ===

# Regla 1000020: Detecta flags del CTF transitando en texto plano
alert http any any -> any any (msg:"CTF - Flag detectada en trafico HTTP"; content:"FLAG{"; nocase; sid:1000020; rev:1; classtype:bad-unknown;)

# Regla 1000022: Detecta acceso a archivos de credenciales
alert http any any -> any any (msg:"CTF - Acceso a archivo de credenciales (db_credentials)"; content:"db_credentials"; nocase; sid:1000022; rev:1; classtype:bad-unknown;)
